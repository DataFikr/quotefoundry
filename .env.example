# Copy to .env and fill in. Until VITE_SUPABASE_* are set the app runs against
# the in-memory mock backend (src/mock-supabase).
# NOTE: VITE_SUPABASE_URL is the BARE project URL (https://<ref>.supabase.co) —
# do NOT append /rest/v1/.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- server-side only (set as Vercel env vars; never exposed to the client) --
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=
EMAIL_SEND_DOMAIN=send.quotefoundry.app
PUBLIC_URL=https://quotefoundry.app
TRACKING_SECRET=

# ---- optional monitoring ------------------------------------------------------
VITE_SENTRY_DSN=
